# TransitOps — Root Environment Variables for Docker Compose

# PostgreSQL Credentials (used by DB container)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase

# Database URL (used by backend)
DATABASE_URL=postgresql://myuser:mypassword@db:5432/mydatabase?schema=public

# SMTP Configurations (used for email OTPs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rishabh.jain.6112@gmail.com
SMTP_PASS=bnzr otfy gqlj sruf
SMTP_FROM="TransitOps <rishabh.jain.6112@gmail.com>"

# pgAdmin Configurations
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
