# TransitOps Backend — Local Development Configuration
# Copy to .env and fill in your own values. Never commit .env.

# PostgreSQL Local URL
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/transitops?schema=public"

# SMTP Configuration (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="TransitOps <your.email@gmail.com>"

# Redis Local Host
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server Ports
PORT=5000
FRONTEND_URL=http://localhost:3000
