// TransitOps — Prisma Schema
// Roles: Fleet Manager | Dispatcher | Safety Officer | Financial Analyst

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Role ────────────────────────────────────────────────────────────────────
// Pre-seeded. One of: Fleet Manager, Dispatcher, Safety Officer, Financial Analyst.
model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]

  @@map("roles")
}

// ─── User ────────────────────────────────────────────────────────────────────
// Users are pre-seeded — no self-registration.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([roleId])
  @@map("users")
}

/**
 * Represents the operational status of a vehicle.
 *
 * AVAILABLE - Vehicle can be assigned to a trip.
 * ON_TRIP   - Vehicle is currently assigned to an active trip.
 * IN_SHOP   - Vehicle is currently under maintenance.
 * RETIRED   - Vehicle is permanently removed from active operations.
 */
enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

/**
 * Vehicle
 *
 * Stores the master registry of all vehicles managed by TransitOps.
 * Registration number is globally unique within the organization.
 */
model Vehicle {
  id                  String        @id @default(uuid())
  registrationNumber  String        @unique
  name                String
  type                String
  region              String        @default("Central")
  maxLoadCapacity     Float
  odometer            Float
  acquisitionCost     Float
  status              VehicleStatus @default(AVAILABLE)

  trips               Trip[]
  maintenances        Maintenance[]
  fuelLogs            FuelLog[]
  expenses            Expense[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([type, status])
  @@index([region])
  @@index([createdAt])
  @@map("vehicles")
}

/**
 * License category endorsed on an Indian driving license.
 *
 * LMV_TR - Light Motor Vehicle (Transport)
 * MGV    - Medium Goods Vehicle
 * HMV    - Heavy Motor Vehicle
 */
enum LicenseCategory {
  LMV_TR
  MGV
  HMV
}

/**
 * Represents the operational status of a driver.
 *
 * AVAILABLE - Driver can be assigned to a trip.
 * ON_TRIP   - Driver is currently assigned to an active trip (owned by the Dispatcher/Trip lifecycle).
 * OFF_DUTY  - Driver is not currently working.
 * SUSPENDED - Driver is blocked from assignment (safety incident or expired license).
 */
enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

/**
 * Driver
 *
 * Maintained by the Safety Officer. Safety score is a cached average
 * derived from SafetyRating entries submitted by the Dispatcher after
 * each completed trip — never set directly on this record.
 */
model Driver {
  id                 String          @id @default(uuid())
  name               String
  licenseNumber      String          @unique
  licenseCategory    LicenseCategory
  licenseExpiry      DateTime
  contactNumber      String
  email              String?
  safetyScore        Float           @default(5)
  safetyRatingCount  Int             @default(0)
  status             DriverStatus    @default(AVAILABLE)
  // Set when a license-renewal reminder email has been sent for the
  // *current* expiry date; cleared once the license is renewed past the
  // reminder window so a future re-expiry can trigger a fresh email.
  renewalEmailSentAt DateTime?

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  safetyRatings      SafetyRating[]
  trips              Trip[]

  @@index([status])
  @@index([licenseExpiry])
  @@index([createdAt])
  @@map("drivers")
}

/**
 * SafetyRating
 *
 * One row per completed trip. Submitted by the Dispatcher (1-5 scale)
 * once the trip-completion flow exists; Driver.safetyScore is the
 * running average of these ratings.
 */
model SafetyRating {
  id        String   @id @default(uuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  tripId    String   @unique
  trip      Trip     @relation(fields: [tripId], references: [id])
  score     Int
  createdAt DateTime @default(now())

  @@index([driverId])
  @@map("safety_ratings")
}

/**
 * Trip lifecycle: Draft -> Dispatched -> Completed / Cancelled.
 */
enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

/**
 * Trip
 *
 * Owned by the Dispatcher module: create/dispatch/complete/cancel. The
 * Safety Officer module reads it read-only for the driver detail/trips views.
 */
model Trip {
  id              String     @id @default(uuid())
  source          String
  destination     String
  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver     @relation(fields: [driverId], references: [id])
  cargoWeight     Float
  plannedDistance Float
  revenue         Float      @default(0) // Per-trip revenue for ROI calculations
  status          TripStatus @default(DRAFT)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  safetyRating    SafetyRating?
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([driverId])
  @@index([vehicleId])
  @@index([createdAt])
  @@map("trips")
}

/**
 * FuelLog
 *
 * Fuel purchase/consumption record for a vehicle, optionally tied to the
 * trip it was logged during (e.g. on trip completion).
 */
model FuelLog {
  id        String   @id @default(uuid())
  liters    Float
  cost      Float
  date      DateTime @default(now())

  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@map("fuel_logs")
}

/**
 * Expense
 *
 * Miscellaneous per-vehicle costs that aren't fuel or maintenance — tolls,
 * parking, fines, etc. Kept as its own entity per the spec's data model
 * (Maintenance Logs, Fuel Logs, and Expenses are listed separately).
 * Not part of the Fuel+Maintenance "operational cost" KPI formula — that
 * formula is defined by the spec as exactly those two, nothing else.
 */
model Expense {
  id          String   @id @default(uuid())
  type        String   // e.g. "Toll", "Parking", "Fine", "Other"
  amount      Float
  date        DateTime @default(now())
  description String?

  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  tripId      String?
  trip        Trip?    @relation(fields: [tripId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vehicleId])
  @@map("expenses")
}

/**
 * MaintenanceStatus
 *
 * ACTIVE - Maintenance is in progress. Vehicle is IN_SHOP.
 * CLOSED - Maintenance is completed. Vehicle is restored to AVAILABLE.
 */
enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

/**
 * Maintenance
 *
 * Tracks all maintenance records for TransitOps vehicles.
 * A single vehicle can have multiple maintenance records over time.
 *
 * Creating an ACTIVE record sets the vehicle status to IN_SHOP.
 * Closing (CLOSED) the record restores the vehicle to AVAILABLE.
 */
model Maintenance {
  id            String            @id @default(uuid())
  vehicleId     String
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])

  type          String            // e.g. "Oil Change", "Brake Repair"
  description   String?           // Optional extended description
  cost          Float             @default(0)
  startDate     DateTime
  completedDate DateTime?         // Set when status transitions to CLOSED

  status        MaintenanceStatus @default(ACTIVE)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([vehicleId])
  @@index([status])
  @@map("maintenances")
}
